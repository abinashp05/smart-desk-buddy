import pyttsx3
import threading
import time


class VoiceAssistant:
    def __init__(self):
        self.engine = pyttsx3.init()
        self._configure_voice()
        self._speaking = False
        self._lock = threading.Lock()

        # Cooldowns to avoid spamming
        self._last_bad_posture_alert = 0
        self._last_break_reminder    = 0

        # Intervals
        self.BAD_POSTURE_COOLDOWN = 30   # seconds between bad posture alerts
        self.BREAK_REMINDER_INTERVAL = 30 * 60  # 30 minutes

        # Session start for break reminder
        self._session_start = time.time()

        # Start break reminder background thread
        self._break_thread = threading.Thread(target=self._break_reminder_loop)
        self._break_thread.daemon = True
        self._break_thread.start()

        print("🎤 Voice Assistant initialized")

    def _configure_voice(self):
        """Set voice properties."""
        self.engine.setProperty('rate', 160)    # Speed (default ~200)
        self.engine.setProperty('volume', 1.0)  # Max volume

        # Try to use a female voice if available
        voices = self.engine.getProperty('voices')
        for voice in voices:
            if 'female' in voice.name.lower() or 'zira' in voice.name.lower():
                self.engine.setProperty('voice', voice.id)
                break

    def _speak(self, text):
        """Speak text in a separate thread to avoid blocking."""
        def run():
            with self._lock:
                self._speaking = True
                try:
                    # Re-init engine in thread to avoid conflicts
                    engine = pyttsx3.init()
                    engine.setProperty('rate', 160)
                    engine.setProperty('volume', 1.0)
                    voices = engine.getProperty('voices')
                    for voice in voices:
                        if 'female' in voice.name.lower() or 'zira' in voice.name.lower():
                            engine.setProperty('voice', voice.id)
                            break
                    engine.say(text)
                    engine.runAndWait()
                    engine.stop()
                except Exception as e:
                    print(f"Voice error: {e}")
                finally:
                    self._speaking = False

        t = threading.Thread(target=run)
        t.daemon = True
        t.start()

    def alert_bad_posture(self, issues=None):
        """
        Called when bad posture is detected.
        Respects cooldown to avoid repeating every second.
        """
        now = time.time()
        if now - self._last_bad_posture_alert < self.BAD_POSTURE_COOLDOWN:
            return  # Still in cooldown

        self._last_bad_posture_alert = now

        if issues and len(issues) > 0:
            # Speak the specific issue
            first_issue = issues[0].split('(')[0].strip()  # Remove angle info
            message = f"Posture warning! {first_issue}. Please correct your posture."
        else:
            message = "Warning! Bad posture detected. Please sit up straight."

        print(f"🔊 Speaking: {message}")
        self._speak(message)

    def alert_posture_corrected(self):
        """Called when posture improves after a bad period."""
        message = "Great job! Your posture is now correct. Keep it up!"
        print(f"🔊 Speaking: {message}")
        self._speak(message)

    def _break_reminder_loop(self):
        """Background thread that reminds user to take a break every 30 mins."""
        # Wait 30 mins before first reminder
        time.sleep(self.BREAK_REMINDER_INTERVAL)

        while True:
            message = (
                "You have been sitting for 30 minutes. "
                "Please stand up, stretch, and take a short break. "
                "It improves your health and productivity."
            )
            print(f"🔊 Break reminder: {message}")
            self._speak(message)
            time.sleep(self.BREAK_REMINDER_INTERVAL)

    def speak(self, text):
        """Generic speak method for any custom message."""
          self._speak(text)
